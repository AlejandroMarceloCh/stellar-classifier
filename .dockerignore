# Excluir del build context (la imagen NO debe llevar venv, parquets, notebooks…)
**/venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.ipynb_checkpoints/

# Datos pesados que NO se usan en runtime (los parquets son intermedios del notebook)
backend/data/*.parquet
backend/data/*.feather
backend/logs/

# Notebooks (no entran al backend)
notebooks/

# Frontend: el backend SOLO necesita frontend/public/data; excluir todo lo demas
# (reduce build context, evita filtrar .env*, build artifacts, source)
frontend/**
!frontend/public/
!frontend/public/data/
!frontend/public/data/**
frontend/.env*

.git/
*.log
session.log
.DS_Store
